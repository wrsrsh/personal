---
import BaseHead from "./BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  pageType?: 'home' | 'default';
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  type,
  pageType,
} = Astro.props;
---

<!doctype html>
<html lang="en"
  class="shadow-none ">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} pageType={pageType} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.15.1/dist/katex.css"
      integrity="sha384-WsHMgfkABRyG494OmuiNmkAOk8nhO1qE+Y6wns6v+EoNoTNxrWxYpl5ZYWFOLPCM"
      crossorigin="anonymous"
    />
  </head>
  <body class="mx-auto max-w-[32rem] px-6 sm:px-5 pt-4 sm:pt-4 pb-0 sm:pb-10 min-h-screen flex flex-col relative">
    <main class="flex-1 motion-reveal" data-reveal style="--reveal-delay: 40ms;">
      <slot />
    </main>
    <script>
      const applyMotionState = () => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        requestAnimationFrame(() => {
          document.body.classList.add("motion-ready");
        });
      };

      document.body.classList.remove("motion-ready");
      applyMotionState();

      document.addEventListener("keydown", (e) => {
        if (
          e.target instanceof HTMLInputElement ||
          e.target instanceof HTMLTextAreaElement ||
          (e.target as HTMLElement).isContentEditable
        ) return;

        if (e.key === "w") {
          window.location.href = "/";
        }
      });
    </script>
  </body>
</html>
