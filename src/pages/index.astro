---
import { Image } from "astro:assets";
import Layout from "../components/Layout.astro";
import image1 from "../assets/image-1.webp";
import image2 from "../assets/image-2.webp";
import image3 from "../assets/image-3.webp";

const images = [
  { src: image1, rotate: "-9deg", z: "z-30" },
  { src: image2, rotate: "4deg", z: "z-20" },
  { src: image3, rotate: "12deg", z: "z-10" },
];
---

<Layout>
  <section
    class="prose min-h-[calc(100vh-8rem)] flex flex-col justify-center"
  >
    <div class="flex items-center mb-12" aria-hidden="true">
      {images.map((img, i) => (
        <div
          class:list={[
            "group relative w-32 h-40 hover:z-50",
            img.z,
            i > 0 && "-ml-4",
          ]}
        >
          <div
            class:list={[
              "absolute inset-0 origin-bottom rounded-2xl overflow-hidden shadow-lg bg-neutral-800",
              "transition-[rotate,translate,scale,box-shadow] duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]",
              "group-hover:rotate-0 group-hover:-translate-y-3 group-hover:scale-[1.06] group-hover:shadow-2xl",
            ]}
            style={`rotate: ${img.rotate};`}
          >
            <Image src={img.src} alt="" class="w-full h-full object-cover block scale-120" />
          </div>
        </div>
      ))}
    </div>

    <h1 class="text-lg font-medium leading-tight m-0">waris reshi</h1>
    <p class="m-0 mb-4 leading-tight text-[var(--color-muted)]">engineer, founder</p>

    <p class="text-[var(--color-muted)]">
      I work at <a href="https://asent.app" target="_blank">Asent</a>, building AI infra for sales teams. Previously ran a sales agency. I grew up in Kashmir and started building software at age 8.
    </p>
    <p class="text-[var(--color-muted)]">
      I keep a <a href="https://warism.substack.com" target="_blank">blog</a>. You can reach me at <a href="mailto:waris@asent.app">waris@asent.app</a>
    </p>
  </section>
</Layout>
